// ============================================================================
// CI/CD Pipeline: Unit Tests → Package → Deploy Test → Integration → Smoke → E2E → Tag → Publish → GitOps Update
// Only master runs the full pipeline; feature/* branches run only unit tests (+ integration with [run-integration] flag)
// ============================================================================
pipeline {
    agent any


    options {
        timeout(time: 20, unit: 'MINUTES')  // Fail-safe: kill stuck builds
        gitLabConnection('gitlab-connection')  // Enables GitLab commit status updates
    }



    environment {
        ECR_REGION = 'ap-south-1'
        ECR_REPO = 'tellme'
        ECR_REGISTRY = '695547473633.dkr.ecr.ap-south-1.amazonaws.com'
        AWS_CLI_IMAGE = 'amazon/aws-cli:2.15.40'  // Fallback if aws CLI not installed on Jenkins agent
        GITOPS_REPO = 'git@gitlab.com:salihdaher9/tellme-gitops.git'
        GITOPS_BRANCH = 'master'
        GITOPS_VALUES_PATH = 'values/tellme-prod.yaml'  // File where image tag gets updated
        SLACK_CHANNEL = '#jenkins-salih'
    }

    stages {

        // ---- Stage 1: Unit Tests (parallel backend + frontend) ----
        // Runs on master AND feature/* branches (fast feedback for PRs)
        stage('Unit Tests') {
            when {
                anyOf {
                    branch 'master'
                    branch 'feature/*'
                }
            }
            parallel {
                stage('Backend Unit') {
                    steps {
                        script {
                            // Run inside a Docker container — ensures consistent Node.js version
                            docker.image('node:20-bullseye').inside {
                                dir('backend') {
                                    sh 'npm ci'
                                    sh 'npm test -- test/unit'
                                }
                            }
                        }
                    }
                }
                stage('Frontend Unit') {
                    steps {
                        script {
                            docker.image('node:20-bullseye').inside {
                                dir('frontend') {
                                    sh 'npm ci'
                                    sh 'npm test'
                                }
                            }
                        }
                    }
                }
            }
        }

        // ---- Versioning: read VERSION file → fetch last git tag → calculate next tag ----
        // Auto-increment: if VERSION=1.0 and last tag=v1.0.24, next tag=v1.0.25
        // If VERSION changes (e.g., 1.1), patch resets to 0 → v1.1.0
        stage('Versioning') {
            when {
                branch 'master'
            }
            steps {
                withCredentials([sshUserPrivateKey(credentialsId: 'git', keyFileVariable: 'SSH_KEY')]) {
                    script {
                        env.VERSION_BASE = readVersionBase()
                        echo "VERSION_BASE=${env.VERSION_BASE}"

                        env.LAST_TAG = sh(
                            returnStdout: true,
                            script: '''
                                set -e
                                GIT_SSH_COMMAND="ssh -i $SSH_KEY -o StrictHostKeyChecking=no" git fetch --tags >/dev/null 2>&1 || true
                                git describe --tags --abbrev=0 2>/dev/null || echo v0.0.0
                            '''
                        ).trim()
                        echo "LAST_TAG=${env.LAST_TAG}"

                        env.NEXT_TAG = calculateNextTag(env.VERSION_BASE, env.LAST_TAG)
                        if (!env.NEXT_TAG?.trim()) {
                            error("NEXT_TAG could not be calculated (VERSION_BASE='${env.VERSION_BASE}', LAST_TAG='${env.LAST_TAG}')")
                        }
                        echo "NEXT_TAG=${env.NEXT_TAG}"

                        writeFile(file: 'VERSION', text: "${env.NEXT_TAG.replaceFirst('^v', '')}\n")

                        // Set RELEASE_TAG once for all downstream stages
                        env.RELEASE_TAG = env.NEXT_TAG
                    }
                }
            }
        }

        // ---- Stage 2: Build Docker image ----
        stage('Package') {
            when {
                anyOf {
                    branch 'master'
                    // Feature branches can opt-in to integration tests via commit message flag
                    expression { env.BRANCH_NAME?.startsWith('feature/') && commitHasFlag('[run-integration]') }
                }
            }
            steps {
                script {
                    def tag = (env.BRANCH_NAME == 'master') ? env.RELEASE_TAG : env.BRANCH_NAME
                    docker.build("myapp:${tag}")
                }
            }
        }

        // ---- Stage 3: Deploy test environment via docker compose ----
        stage('Deploy Test Environment') {
            when {
                branch 'master'
            }
            steps {
                sh 'docker compose --env-file .env.test up -d --build'
                sh 'sleep 10'  // Wait for all services to stabilize
            }
        }

        // ---- Stage 4: Integration tests (runs inside the app container against real MongoDB) ----
        stage('Integration Tests') {
            when {
                anyOf {
                    branch 'master'
                    expression { env.BRANCH_NAME?.startsWith('feature/') && commitHasFlag('[run-integration]') }
                }
            }
            steps {
                sh 'docker compose --env-file .env.test exec -T app node --test backend/test/integration' // Runs the integration test suite inside the app container, which connects to the real MongoDB service defined in docker compose
            }
        }

        // ---- Stage 5: Smoke tests (basic health + auth checks via curl) ----
        stage('Smoke Tests') {
            when {
                branch 'master'
            }
            steps {
                sh 'docker compose --env-file .env.test run --rm smoke-tests'
            }
        }

        // ---- Stage 6: E2E tests (full user journey via curl) ----
        stage('E2E Tests') {
            when {
                branch 'master'
            }
            steps {
                sh 'docker compose --env-file .env.test run --rm e2e-tests'
            }
        }

        // ---- Stage 7: Tag the git commit with the new version ----
        stage('Tag Release') {
            when {
                branch 'master'
            }
            steps {
                withCredentials([sshUserPrivateKey(credentialsId: 'git', keyFileVariable: 'SSH_KEY')]) {
                    sh '''
                        set -e
                        tag="${RELEASE_TAG}"
                        git config user.email "jenkins@lidar.com"
                        git config user.name "Jenkins CI"
                        GIT_SSH_COMMAND="ssh -i $SSH_KEY -o StrictHostKeyChecking=no" git tag -a "${tag}" -m "Release ${tag}"
                        GIT_SSH_COMMAND="ssh -i $SSH_KEY -o StrictHostKeyChecking=no" git push origin "${tag}"
                    '''
                }
            }
        }

        // ---- Stage 8: Push Docker image to ECR ----
        // Tags with both version (v1.0.25) and git SHA for traceability
        stage('Publish') {
            when {
                branch 'master'
            }
            steps {
                sh '''
                    set -e
                    tag="${RELEASE_TAG}"
                    sha="$(git rev-parse --short HEAD)"
                    repo="${ECR_REGISTRY}/${ECR_REPO}"
                    # Authenticate to ECR — uses aws CLI if available, otherwise runs it via Docker
                    if command -v aws >/dev/null 2>&1; then
                        aws ecr get-login-password --region "${ECR_REGION}" | docker login --username AWS --password-stdin "$repo"
                    else
                        docker run --rm -e AWS_REGION="${ECR_REGION}" "${AWS_CLI_IMAGE}" ecr get-login-password | docker login --username AWS --password-stdin "$repo"
                    fi
                    docker tag "myapp:${tag}" "$repo:${tag}"
                    docker tag "myapp:${tag}" "$repo:${sha}"
                    docker push "$repo:${tag}"
                    docker push "$repo:${sha}"
                '''
            }
        }

        // ---- Stage 9: Update GitOps repo (triggers ArgoCD deployment) ----
        // This is the GitOps bridge: CI pushes a new image tag → GitOps repo updates →
        // ArgoCD detects the change → syncs the new image to the cluster
        stage('Update GitOps') {
            when {
                branch 'master'
            }
            steps {
                withCredentials([sshUserPrivateKey(credentialsId: 'git', keyFileVariable: 'SSH_KEY')]) {
                    sh '''
                        set -euo pipefail

                        # Get tag
                        tag="${RELEASE_TAG}"

                        # Clone GitOps repo into a temp directory
                        workdir="$(mktemp -d)"
                        trap 'rm -rf "$workdir"' EXIT
                        export GIT_SSH_COMMAND="ssh -i $SSH_KEY -o StrictHostKeyChecking=no"

                        git clone --branch "${GITOPS_BRANCH}" "${GITOPS_REPO}" "$workdir"

                        # Update the image tag in the prod values file using sed
                        values_file="$workdir/${GITOPS_VALUES_PATH}"
                        [ ! -f "$values_file" ] && { echo "Values file not found: $values_file" >&2; exit 1; }

                        # Prefer yq for structured YAML updates; fallback to sed for compatibility.
                        if command -v yq >/dev/null 2>&1; then
                            yq -i '.app.image.tag = "'"${tag}"'"' "$values_file"
                        else
                            sed -i -E "s#^(\\s*tag:)\\s*\".*\"#\\1 \"${tag}\"#g" "$values_file"
                        fi

                        # Commit and push — this triggers ArgoCD to sync the new version
                        cd "$workdir"
                        git config user.email "jenkins@lidar.com"
                        git config user.name "Jenkins CI"
                        git add "${GITOPS_VALUES_PATH}"
                        git commit -m "Update tellme image tag to ${tag}"
                        git push origin "${GITOPS_BRANCH}"
                    '''
                }
            }
        }


    }

    // ---- Post-build actions: cleanup, notifications, status updates ----
    post {
        always {
            // Always tear down test environment (even on failure)
            sh 'docker compose --env-file .env.test down'
            // Restore VERSION file to original state (keep repo clean)
            sh '''
                if [ -n "${VERSION_BASE:-}" ] && [ -f VERSION ]; then
                    echo "$VERSION_BASE" > VERSION
                fi
            '''
            // Send Slack notification with build result (green/red/yellow)
            script {
                def status = currentBuild.currentResult
                def color = (status == 'SUCCESS') ? 'good' : (status == 'FAILURE') ? 'danger' : 'warning'
                slackSend(
                    channel: env.SLACK_CHANNEL,
                    color: color,
                    message: "${env.JOB_NAME} #${env.BUILD_NUMBER} - ${status}\n${env.BUILD_URL}"
                )
            }
        }
        // Update GitLab commit status (shows green checkmark / red X on the commit in GitLab)
        success {
            script {
                try {
                    updateGitlabCommitStatus name: 'build', state: 'success'
                } catch (err) {
                    echo "GitLab status update failed: ${err}"
                }
            }
        }
        failure {
            script {
                try {
                    updateGitlabCommitStatus name: 'build', state: 'failed'
                } catch (err) {
                    echo "GitLab status update failed: ${err}"
                }
            }
        }
    }
}



// ============================================================================
// Helper Functions
// ============================================================================

// Reads MAJOR.MINOR from the VERSION file (e.g., "1.0")
def readVersionBase() {
    if (!fileExists('VERSION')) {
        error('VERSION file missing')
    }
    def base = readFile('VERSION').trim()
    if (!(base ==~ /[0-9]+\.[0-9]+/)) {
        error("Invalid VERSION '${base}' (expected MAJOR.MINOR)")
    }
    return base
}

// Calculates the next semver tag by incrementing the patch number
// Example: VERSION=1.0, lastTag=v1.0.24 → returns "v1.0.25"
// If VERSION changed (e.g., 1.1), patch resets: v1.1.0
def calculateNextTag(String versionBase, String lastTag) {
    def safeLast = lastTag ?: 'v0.0.0'
    def baseValue = (versionBase ?: readVersionBase())?.trim()
    if (!baseValue) {
        return ''
    }
    if (!(baseValue ==~ /[0-9]+\.[0-9]+/)) {
        return ''
    }
    def baseParts = baseValue.split('\\.')
    def major = baseParts[0] as int
    def minor = baseParts[1] as int

    def lastClean = safeLast.startsWith('v') ? safeLast.substring(1) : safeLast
    def lastParts = lastClean.split('\\.')
    def lastMajor = (lastParts.size() > 0 ? lastParts[0] : '0') as int
    def lastMinor = (lastParts.size() > 1 ? lastParts[1] : '0') as int
    def lastPatch = (lastParts.size() > 2 ? lastParts[2] : '0') as int

    // If major.minor matches last tag, increment patch; otherwise reset to 0
    def nextPatch = (major == lastMajor && minor == lastMinor) ? (lastPatch + 1) : 0
    return "v${major}.${minor}.${nextPatch}"
}

// Checks if the latest commit message contains a flag (e.g., "[run-integration]")
// Used to let feature branches opt-in to integration tests via commit message
def commitHasFlag(String flag) {
    def msg = sh(
        returnStdout: true,
        script: '''
            set -e
            git log -1 --pretty=%B
        '''
    ).trim()
    return msg?.contains(flag)
}
