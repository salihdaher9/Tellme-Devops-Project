# Separate image for database seeding — runs once to populate initial data, then exits
# Runs as a one-shot container via docker compose --profile seed
FROM node:18-slim

WORKDIR /seed

COPY db/package*.json ./
RUN npm ci --only=production  # --only=production: skip devDependencies (not needed for seeding)

COPY db ./

CMD ["node", "seed.js"]
